# Public site URL
SITE_URL=https://sippomi.com
PUBLIC_SITE_URL=http://localhost:5173

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Server-side only. Never expose this in browser code.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=
# Server-side only. Never expose this in browser code.
TURNSTILE_SECRET_KEY=

# Sentry
SENTRY_DSN=
# Needed only if you later upload source maps from CI or Vercel.
SENTRY_AUTH_TOKEN=

# Google Analytics GA4 (optional; skipped if not set)
GA4_MEASUREMENT_ID=

# Optional: keep these aligned with .vercel/project.json for CLI usage.
VERCEL_ORG_ID=team_xxxxxxxxxxxxxxxxxxxxxxxx
VERCEL_PROJECT_ID=prj_xxxxxxxxxxxxxxxxxxxxxxxxxx
