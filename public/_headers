# Cloudflare Pages headers (vercel.json から移行)

/*
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; script-src 'self' https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https://sippomi.com https://pet-namer.vercel.app https://pet-namer.pages.dev https://*.supabase.co https://images.unsplash.com https://images.pexels.com https://upload.wikimedia.org https://hbb.afl.rakuten.co.jp https://thumbnail.image.rakuten.co.jp https://static.affiliate.rakuten.co.jp https://image.rakuten.co.jp; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://*.ingest.sentry.io https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; upgrade-insecure-requests

/llms.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600, s-maxage=3600
  X-Robots-Tag: all

/llms-full.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600, s-maxage=3600
  X-Robots-Tag: all

/images/*
  Cache-Control: public, max-age=2592000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable
